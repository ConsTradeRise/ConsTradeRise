generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String         @id @default(uuid())
  name                String
  email               String         @unique
  passwordHash        String
  role                Role           @default(WORKER)
  emailVerified       Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  isVerified          Boolean        @default(false)
  passwordResetExpiry DateTime?
  passwordResetToken  String?
  emailVerifyExpiry   DateTime?
  emailVerifyToken    String?
  applications        Application[]
  atsResults          AtsResult[]
  jobAlerts           JobAlert[]
  jobReports          JobReport[]
  postedJobs          Job[]          @relation("EmployerJobs")
  receivedMessages    Message[]      @relation("ReceivedMessages")
  sentMessages        Message[]      @relation("SentMessages")
  notifications       Notification[]
  profile             Profile?
  resumes             Resume[]
  savedJobs           SavedJob[]

  @@map("users")
}

model Profile {
  id                 String   @id @default(uuid())
  userId             String   @unique
  phone              String?
  location           String?
  city               String?
  province           String?
  skills             String[]
  yearsExperience    Int?
  availability       String?
  visibleToEmployers Boolean  @default(true)
  openToMatching     Boolean  @default(true)
  companyName        String?
  companySize        String?
  industry           String?
  website            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  certifications     Json?
  country            String?  @default("Canada")
  driversLicence     String?
  educations         Json?
  email              String?
  experiences        Json?
  headline           String?
  linkedin           String?
  openToRelocation   Boolean  @default(false)
  skillCategories    Json?
  summary            String?
  profileViews       Int      @default(0)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Resume {
  id           String        @id @default(uuid())
  userId       String
  name         String        @default("My Resume")
  content      String?
  fileUrl      String?
  isDefault    Boolean       @default(false)
  aiGenerated  Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  atsResults   AtsResult[]
  versions     ResumeVersion[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resumes")
}

// ─────────────────────────────────────────────
//  RESUME VERSIONS (version history)
// ─────────────────────────────────────────────

model ResumeVersion {
  id          String   @id @default(uuid())
  resumeId    String
  resume      Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  userId      String

  version     Int
  label       String   @default("Version")
  content     String
  tailoredFor String?
  aiGenerated Boolean  @default(false)

  createdAt   DateTime @default(now())

  @@unique([resumeId, version])
  @@map("resume_versions")
}

model Job {
  id           String        @id @default(uuid())
  title        String
  description  String
  location     String
  city         String?
  province     String?
  salary       String?
  jobType      String?
  skills       String[]
  source       JobSource     @default(MANUAL)
  externalId   String?
  externalUrl  String?
  employerId   String?
  companyName  String?
  isActive     Boolean       @default(true)
  isFeatured   Boolean       @default(false)
  postedAt     DateTime      @default(now())
  expiresAt    DateTime?
  updatedAt    DateTime      @updatedAt
  viewCount    Int           @default(0)
  applications Application[]
  atsResults   AtsResult[]
  employer     User?         @relation("EmployerJobs", fields: [employerId], references: [id])
  matches      Match[]
  savedBy      SavedJob[]

  @@map("jobs")
}

model Application {
  id          String            @id @default(uuid())
  userId      String
  jobId       String
  resumeId    String?
  status      ApplicationStatus @default(APPLIED)
  coverLetter String?
  notes       String?
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume      Resume?           @relation(fields: [resumeId], references: [id])
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  interview   Interview?

  @@unique([userId, jobId])
  @@map("applications")
}

model Interview {
  id            String      @id @default(uuid())
  applicationId String      @unique
  employerId    String
  workerId      String
  proposedDates Json
  acceptedDate  String?
  status        String      @default("PENDING")
  location      String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("interviews")
}

model AtsResult {
  id              String   @id @default(uuid())
  userId          String
  jobId           String
  resumeId        String?
  score           Int
  keywordScore    Int?
  skillsScore     Int?
  experienceScore Int?
  titleScore      Int?
  formatScore     Int?
  matchedKeywords String[]
  missingKeywords String[]
  suggestions     String[]
  matchStrength   String?
  createdAt       DateTime @default(now())
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume          Resume?  @relation(fields: [resumeId], references: [id])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId, resumeId])
  @@map("ats_results")
}

model Match {
  id        String   @id @default(uuid())
  jobId     String
  userId    String
  score     Int
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@map("matches")
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model JobReport {
  id        String   @id @default(uuid())
  jobId     String
  userId    String
  reason    String
  details   String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@map("job_reports")
}

model SavedJob {
  id      String   @id @default(uuid())
  userId  String
  jobId   String
  savedAt DateTime @default(now())
  job     Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("saved_jobs")
}

model JobAlert {
  id        String   @id @default(uuid())
  userId    String
  keywords  String
  province  String?
  jobType   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("job_alerts")
}

enum Role {
  WORKER
  EMPLOYER
  ADMIN
}

enum JobSource {
  MANUAL
  API
}

enum ApplicationStatus {
  APPLIED
  VIEWED
  SHORTLISTED
  REJECTED
}
