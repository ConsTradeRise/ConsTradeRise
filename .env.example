# ─────────────────────────────────────────────
#  TradesUp AI — Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL — use Supabase for easy setup)
# Get from: https://supabase.com → Settings → Database → Connection String
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tradesup?schema=public"

# JWT Secret (generate a long random string)
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d

# Anthropic Claude AI
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# File Storage (Cloudflare R2 or AWS S3)
# For Phase 1, files stored locally. Set these up in Phase 4.
# STORAGE_BUCKET=tradesup-files
# STORAGE_ACCESS_KEY=your_key
# STORAGE_SECRET_KEY=your_secret
# STORAGE_ENDPOINT=your_endpoint

# Job APIs (live aggregation)
# Adzuna: https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# Jooble: https://jooble.org/api/employer
JOOBLE_API_KEY=your_jooble_api_key

# Email (Phase 4 — use Resend for easy setup)
# Get from: https://resend.com
# RESEND_API_KEY=your_resend_api_key
# EMAIL_FROM=noreply@tradesup.ca
