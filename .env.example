# ─── Database (Supabase PostgreSQL) ─────────────────────────────────────────
# Get both from Supabase → Settings → Database → Connection String
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ca-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-ca-central-1.pooler.supabase.com:5432/postgres

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# ─── Supabase Storage (resume file uploads) ──────────────────────────────────
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─── AI (optional — disabling skips cover letter and interview prep) ──────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Job Feeds ───────────────────────────────────────────────────────────────
ADZUNA_APP_ID=
ADZUNA_API_KEY=
JOOBLE_API_KEY=

# Apify (optional scraping fallback)
APIFY_TOKEN=
APIFY_ACTOR_ID=
APIFY_DATASET_ID=

# ─── Email ────────────────────────────────────────────────────────────────────
# Option A: Resend API (recommended — free 3k emails/mo, no Gmail needed)
#   1. Sign up free at https://resend.com
#   2. Add and verify your domain (or use onboarding@resend.dev for testing)
#   3. Create an API key and paste it below
RESEND_API_KEY=re_...
EMAIL_FROM=ConsTradeHire <noreply@constradehire.com>

# Option B: Gmail SMTP (alternative)
#   Enable 2FA on Gmail → myaccount.google.com → App Passwords → create one
EMAIL_USER=your@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# ─── External APIs (optional features) ───────────────────────────────────────
IPSTACK_API_KEY=
MAILBOXLAYER_API_KEY=
NUMVERIFY_API_KEY=
MEDIASTACK_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL=https://constradehire.com
PORT=3000
NODE_ENV=production
