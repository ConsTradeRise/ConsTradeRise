{
  "version": 2,
  "buildCommand": "npx prisma generate",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": "public/**|utils/**|middleware/**|routes/**|prisma/schema.prisma"
      }
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/server.js" }
  ]
}
